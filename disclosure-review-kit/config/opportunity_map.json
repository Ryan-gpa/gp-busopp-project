{
  "meta": {
    "purpose": "Business-development lens for Growth Partners Advisory. RAG-flags each ASX announcement by whether it signals a need GP can serve.",
    "ragMeaning": {
      "GREEN": "Clear, near-term opportunity to offer a GP service",
      "AMBER": "Possible opportunity — monitor / qualify",
      "RED": "Routine, administrative or investor-relations disclosure — no direct service trigger"
    },
    "logic": "Rules are evaluated top-to-bottom (GREEN first); an announcement takes the first rule whose tokens appear in its type or headline, so the highest-ranking signal wins. Tokens are matched case-insensitively as substrings.",
    "confirm": [
      "progress_report rule and trading_halt rule are judgement calls flagged for GP sign-off — see README/FEEDBACK"
    ],
    "priorityBands": {
      "1": "High",
      "2": "High",
      "3": "Medium",
      "4": "Low",
      "5": "None"
    },
    "priorityNote": "priority 1 = most important opportunity type to GP (e.g. acquisitions); higher numbers = lower importance. Banded High/Medium/Low for display. Tune to GP's strategy.",
    "themeNote": "Neutral, client-facing category shown in the main report. The RAG + GP service mapping is internal-only (engagement-opportunities appendix).",
    "serviceLines": [
      "Transaction Readiness",
      "Financial Reporting",
      "Business Process Redesign",
      "Commercial Opportunities",
      "Audit Readiness"
    ],
    "coverageNote": "Rules cover the full ASX announcement taxonomy (86 granular sub-types seen market-wide; see research/ASX_ANNOUNCEMENT_TAXONOMY.md). No type falls through to the default - every announcement is explicitly classified, to support the next-phase learning from user experience."
  },
  "rules": [
    {
      "id": "ma_transaction",
      "rag": "GREEN",
      "service": "Transaction Readiness",
      "match": [
        "asset acquisition",
        "asset disposal",
        "acquire",
        "acquisition",
        "disposal of",
        "takeover",
        "bidder's statement",
        "target's statement",
        "off-market bid",
        "on-market bid",
        "scheme of arrangement",
        "merger",
        "divestment",
        "sale of business",
        "binding offer",
        "non-binding",
        "intention to make a takeover",
        "variation of takeover",
        "directors' statement re takeover"
      ],
      "rationale": "M&A / transaction event (acquisition, disposal, takeover, scheme) - GP prepares the business and financials so the deal runs cleanly.",
      "priority": 1,
      "theme": "Strategic transaction",
      "services": [
        "Transaction Readiness"
      ]
    },
    {
      "id": "capital_raise",
      "rag": "GREEN",
      "service": "Transaction Readiness + Financial Reporting",
      "match": [
        "placement",
        "entitlement offer",
        "entitlement issue",
        "rights issue",
        "renounceable",
        "non-renounceable",
        "proposed issue of securities",
        "appendix 3b",
        "capital raising",
        "capital raise",
        "share purchase plan",
        "security purchase plan",
        "purchase plan",
        "prospectus",
        "disclosure document",
        "convertible note",
        "debt facility",
        "alteration to issued capital",
        "shortfall"
      ],
      "rationale": "Capital raise / new funding - transaction readiness, technical accounting for the raise, and investor reporting.",
      "priority": 2,
      "theme": "Capital management",
      "services": [
        "Transaction Readiness",
        "Financial Reporting"
      ]
    },
    {
      "id": "earnings_guidance",
      "rag": "GREEN",
      "service": "Commercial Opportunities + Financial Reporting",
      "match": [
        "profit guidance",
        "earnings guidance",
        "profit upgrade",
        "profit downgrade",
        "trading update",
        "guidance update",
        "earnings update"
      ],
      "rationale": "Earnings / guidance update (auto market-sensitive) - margin & profitability analysis and the numbers behind the guidance.",
      "priority": 2,
      "theme": "Performance update",
      "services": [
        "Commercial Opportunities",
        "Financial Reporting"
      ]
    },
    {
      "id": "periodic_reporting",
      "rag": "GREEN",
      "service": "Financial Reporting + Audit Readiness",
      "match": [
        "annual report",
        "full year",
        "preliminary final",
        "half year",
        "half-year",
        "half yearly",
        "appendix 4e",
        "appendix 4d",
        "appendix 4c",
        "appendix 5b",
        "quarterly activities",
        "quarterly cash flow",
        "monthly activities",
        "commitments test entity",
        "financial report",
        "financial statements",
        "audit review",
        "half year audit"
      ],
      "rationale": "Periodic reporting / audit obligation - statement preparation, technical accounting and audit readiness.",
      "priority": 3,
      "theme": "Financial reporting",
      "services": [
        "Financial Reporting",
        "Audit Readiness"
      ]
    },
    {
      "id": "cfo_finance_lead",
      "rag": "GREEN",
      "service": "Financial Reporting + Business Process Redesign",
      "match": [
        "cfo",
        "chief financial officer",
        "financial controller",
        "head of finance"
      ],
      "rationale": "Finance-leadership change - an immediate gap GP can fill on reporting and process.",
      "priority": 2,
      "theme": "Leadership change",
      "services": [
        "Financial Reporting",
        "Business Process Redesign"
      ]
    },
    {
      "id": "market_status",
      "rag": "AMBER",
      "service": "Transaction Readiness",
      "match": [
        "trading halt",
        "suspension from",
        "reinstatement",
        "pause in trading",
        "trading halt lifted"
      ],
      "rationale": "Market-status event often precedes a capital or transaction event - monitor for a near-term need.",
      "priority": 3,
      "theme": "Market status",
      "services": [
        "Transaction Readiness"
      ]
    },
    {
      "id": "cross_border",
      "rag": "AMBER",
      "service": "Financial Reporting",
      "match": [
        "overseas listing",
        "dual listing",
        "foreign exempt",
        "admission to",
        "commencement of official quotation",
        "removal from official list",
        "delisting",
        "us listing",
        "nasdaq",
        "redomicile"
      ],
      "rationale": "Cross-border / listing-status change - multi-jurisdiction reporting and parent alignment.",
      "priority": 3,
      "theme": "Corporate / listing",
      "services": [
        "Financial Reporting"
      ]
    },
    {
      "id": "reporting_other",
      "rag": "AMBER",
      "service": "Financial Reporting",
      "match": [
        "net tangible asset",
        "periodic reports",
        "notification of results",
        "reporting date",
        "sustainability",
        "climate action",
        "esg report"
      ],
      "rationale": "Reporting-adjacent signal (NTA backing, results/reporting-date notice, sustainability report) - a lead-time signal for reporting/assurance work.",
      "priority": 3,
      "theme": "Financial reporting",
      "services": [
        "Financial Reporting"
      ]
    },
    {
      "id": "leadership_change",
      "rag": "AMBER",
      "service": "Business Process Redesign + Financial Reporting",
      "match": [
        "ceo",
        "managing director",
        "chair appointment",
        "chair resignation",
        "chairman",
        "company secretary appointment",
        "company secretary resignation",
        "executive appointment",
        "key management personnel change"
      ],
      "rationale": "CEO / Chair / Company-Secretary change - leadership transition often opens reporting and process needs.",
      "priority": 4,
      "theme": "Leadership change",
      "services": [
        "Business Process Redesign",
        "Financial Reporting"
      ]
    },
    {
      "id": "ownership_board",
      "rag": "AMBER",
      "service": "Transaction Readiness",
      "match": [
        "change in substantial holding",
        "becoming a substantial holder",
        "ceasing to be a substantial",
        "substantial holder",
        "director appointment",
        "director resignation",
        "appointment of director",
        "board change"
      ],
      "rationale": "Ownership or board change - possible transaction, restructure or finance-function need.",
      "priority": 4,
      "theme": "Ownership & board",
      "services": [
        "Transaction Readiness"
      ]
    },
    {
      "id": "legal_regulatory",
      "rag": "AMBER",
      "service": "Audit Readiness",
      "match": [
        "legal proceedings",
        "litigation",
        "class action",
        "asx query",
        "response to asx query",
        "price query",
        "aware letter",
        "query letter"
      ],
      "rationale": "Legal / regulatory event (ASX query, litigation) - possible controls, governance or audit-readiness need.",
      "priority": 4,
      "theme": "Legal & regulatory",
      "services": [
        "Audit Readiness"
      ]
    },
    {
      "id": "governance_auditor",
      "rag": "AMBER",
      "service": "Audit Readiness",
      "match": [
        "corporate governance",
        "appendix 4g",
        "auditor appointment",
        "auditor resignation",
        "change of auditor",
        "details of auditor"
      ],
      "rationale": "Governance or auditor change - audit-readiness angle.",
      "priority": 4,
      "theme": "Governance & audit",
      "services": [
        "Audit Readiness"
      ]
    },
    {
      "id": "operational_milestone",
      "rag": "AMBER",
      "service": "Commercial Opportunities + Business Process Redesign",
      "match": [
        "progress report",
        "milestone",
        "operational update",
        "commercialisation",
        "production update",
        "scaling"
      ],
      "rationale": "Operational/scaling milestone - possible process-redesign or margin-analysis need as the business grows.",
      "priority": 4,
      "theme": "Operational update",
      "services": [
        "Commercial Opportunities",
        "Business Process Redesign"
      ]
    },
    {
      "id": "buyback_capital",
      "rag": "AMBER",
      "service": "Commercial Opportunities",
      "match": [
        "market buy-back",
        "on-market buy-back",
        "employee share scheme buy-back",
        "buy-back - other",
        "intention to buy back",
        "off-market buy-back"
      ],
      "rationale": "Buy-back initiation - capital-management/advisory angle (note: daily buy-back notices are routine).",
      "priority": 4,
      "theme": "Capital management",
      "services": [
        "Commercial Opportunities"
      ]
    },
    {
      "id": "distribution_routine",
      "rag": "RED",
      "service": "—",
      "match": [
        "dividend record date",
        "dividend pay date",
        "dividend rate",
        "dividend reinvestment",
        "dividend - special",
        "dividend -",
        "distribution announcement",
        "interest record date",
        "interest pay date",
        "interest rate",
        "interest payment"
      ],
      "rationale": "Dividend / interest / distribution administration - no direct service trigger.",
      "priority": 5,
      "theme": "Distribution",
      "services": []
    },
    {
      "id": "products_routine",
      "rag": "RED",
      "service": "—",
      "match": [
        "structured products",
        "mfund",
        "daily fund update",
        "fund update",
        "unit price",
        "end of day",
        "issuer report"
      ],
      "rationale": "Fund / structured-product administration - not a GP service trigger.",
      "priority": 5,
      "theme": "Products / funds",
      "services": []
    },
    {
      "id": "routine_admin",
      "rag": "RED",
      "service": "—",
      "match": [
        "appendix 2a",
        "appendix 3g",
        "appendix 3h",
        "cleansing",
        "issued capital - other",
        "company presentation",
        "web cast",
        "webcast",
        "proxy form",
        "notice of meeting",
        "general meeting",
        "results of meeting",
        "annual general meeting",
        "company administration",
        "top 20",
        "director's interest",
        "interest notice",
        "cessation",
        "letter to shareholders",
        "daily share buy-back",
        "buy-back notice",
        "share buy-back notice",
        "details of company address",
        "registered office",
        "map test",
        "security holder details",
        "notice pending",
        "trading policy",
        "details of registered",
        "commencement of official list"
      ],
      "rationale": "Routine administrative, governance-cadence or investor-relations disclosure - no direct service trigger.",
      "priority": 5,
      "theme": "Administrative",
      "services": []
    }
  ]
}